page {
  overflow: hidden;
}

.discover-page {
  min-height: calc(100vh - 44px - env(safe-area-inset-top));
  padding: 24rpx;
  box-sizing: border-box;
  background: var(--bg);
}

.intro-card {
  padding: 24rpx;
  border-radius: 22rpx;
  border: 1rpx solid var(--border);
  background:
    radial-gradient(circle at top right, rgba(94, 234, 212, 0.2), transparent 56%),
    linear-gradient(145deg, var(--surface), rgba(15, 23, 42, 0.02));
  box-shadow: var(--shadow-soft);
}

.intro-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text);
}

.intro-desc {
  margin-top: 10rpx;
  font-size: 25rpx;
  line-height: 1.6;
  color: var(--text-muted);
}

.space-code {
  margin-top: 18rpx;
  display: inline-flex;
  align-items: center;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(20, 184, 166, 0.14);
  color: var(--primary-strong);
  font-size: 22rpx;
}

.section-title {
  margin-top: 28rpx;
  margin-bottom: 14rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text);
}

.feature-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}

.feature-card {
  border-radius: 20rpx;
  border: 1rpx solid var(--border);
  background: var(--surface);
  padding: 20rpx;
  box-shadow: var(--shadow-soft);
}

.feature-card.notebook {
  border-left: 10rpx solid #22d3ee;
}

.feature-card.wallet {
  border-left: 10rpx solid #14b8a6;
}

.feature-card.activity {
  border-left: 10rpx solid #0ea5e9;
}

.feature-card.emoji {
  border-left: 10rpx solid #f59e0b;
}

.feature-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.feature-name {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text);
}

.feature-tag {
  font-size: 21rpx;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  color: var(--primary-strong);
  background: rgba(20, 184, 166, 0.12);
}

.feature-desc {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.65;
  color: var(--text-muted);
}
